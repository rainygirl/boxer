SECRET_KEY=django-insecure-change-me-to-a-long-random-string
DEBUG=True
JWT_SECRET=change-me-to-a-long-random-string
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
CLIENT_URL=http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1

# Internal backend URL — used by SvelteKit to proxy GitHub webhooks to Django
# In production, set this to the internal address of your Django server
BACKEND_URL=http://127.0.0.1:4173

# 파일 업로드 비활성화 (True로 설정하면 업로드 버튼이 비활성화됨)
DISABLE_FILE_UPLOAD=False

# 데모 모드 (True로 설정하면 모든 로그인 유저가 DEMO_PROJECT_ID 프로젝트에 자동 참여)
DEMO_MODE=False
DEMO_PROJECT_ID=

# Cloudflare R2 (첨부파일 기능, 선택)
# 버킷 생성 후 API 토큰 발급: https://dash.cloudflare.com/?to=/:account/r2/overview
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=boxer
R2_PUBLIC_URL=
